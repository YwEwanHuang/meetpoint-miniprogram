<!-- 首页 - Apple HIG Style -->
<view class="page">

  <!-- Large Title -->
  <view class="large-title">约见</view>

  <!-- 未配对状态 -->
  <block wx:if="{{!hasPair}}">
    <view class="hero-card">
      <view class="hero-icon"><image class="hero-icon-img" src="/assets/tab-home-active.png" mode="aspectFit" /></view>
      <text class="hero-title">找到最好的见面点</text>
      <text class="hero-desc">与重要的人共享位置，智能计算最优相遇地点</text>
    </view>

    <view class="action-section">
      <button class="btn-primary" bindtap="createPair">
        创建配对
      </button>
      <button class="btn-secondary" bindtap="goToPartner">
        输入配对码加入
      </button>
    </view>
  </block>

  <!-- 已配对状态 -->
  <block wx:else>
    <view class="pair-card">
      <view class="pair-status">
        <view class="status-dot active"></view>
        <text class="status-label">已配对</text>
      </view>

      <view class="partner-row" wx:if="{{partner}}">
        <view class="partner-avatar">{{partner.nickname ? partner.nickname.charAt(0) : '?'}}</view>
        <view class="partner-info">
          <text class="partner-name">{{partner.nickname || '对方'}}</text>
          <text class="partner-location" wx:if="{{partner.lat}}">
            位置已更新
          </text>
          <text class="partner-location waiting" wx:else>
            等待对方位置
          </text>
        </view>
      </view>

      <view class="partner-row" wx:else>
        <view class="partner-avatar">?</view>
        <view class="partner-info">
          <text class="partner-name">等待对方加入</text>
          <text class="partner-location waiting">分享配对码给对方</text>
        </view>
      </view>

      <view class="divider"></view>

      <!-- 配对码 -->
      <view class="pair-code-row">
        <view class="pair-code-info">
          <text class="pair-code-label">配对码</text>
          <text class="pair-code-value">{{pairCode}}</text>
        </view>
        <button class="btn-copy" bindtap="copyCode">复制</button>
      </view>

      <!-- 二维码显示 -->
      <view class="qr-section">
        <text class="qr-hint">让对方输入以下配对码加入</text>
        <view class="qr-big-code">{{pairCode}}</view>
        <button class="btn-share-code" bindtap="copyCode">复制配对码</button>
      </view>
    </view>

    <!-- 操作 -->
    <view class="action-section paired">
      <button class="btn-primary large" bindtap="goToMap">
        进入地图
      </button>
      <button class="btn-text-danger" bindtap="showUnpairConfirm">
        解除配对
      </button>
    </view>
  </block>

  <!-- 版本信息 -->
  <view class="version">MeetPoint v1.0</view>

</view>
