<!-- 地图页：位置共享 + 路线 + 相遇点 -->
<view class="container">

  <!-- 地图区域 -->
  <map
    id="mainMap"
    class="map"
    latitude="{{myLocation.latitude}}"
    longitude="{{myLocation.longitude}}"
    scale="14"
    show-location
    markers="{{markers}}"
    polylines="{{polylines}}"
    include-points="{{includePoints}}"
    bindtap="onMapTap"
  ></map>

  <!-- 我方位置标记（左上角） -->
  <view class="location-tag my-tag">
    <text class="tag-icon">🧭</text>
    <text class="tag-text">我的位置</text>
  </view>

  <!-- 对方位置标记（右上角） -->
  <view class="location-tag partner-tag" wx:if="{{partnerLocation.latitude}}">
    <text class="tag-icon">👤</text>
    <text class="tag-text">对方位置</text>
  </view>

  <!-- 刷新位置按钮 -->
  <button class="refresh-btn" bindtap="refreshMyLocation">
    <text>📍</text>
  </button>

  <!-- 底部信息面板 -->
  <view class="bottom-panel {{panelExpanded ? 'expanded' : ''}}">

    <!-- 交通方式选择 -->
    <view class="transport-tabs">
      <view
        wx:for="{{transportModes}}"
        wx:key="mode"
        class="tab-item {{currentMode === item.mode ? 'active' : ''}}"
        bindtap="switchMode"
        data-mode="{{item.mode}}"
      >
        <text>{{item.icon}}</text>
        <text class="tab-label">{{item.label}}</text>
      </view>
    </view>

    <!-- 路线信息（展开后） -->
    <view class="route-info" wx:if="{{routeInfo}}">
      <view class="route-row">
        <view class="route-item">
          <text class="route-icon">📍</text>
          <view class="route-detail">
            <text class="route-distance">{{routeInfo.distance}}</text>
            <text class="route-time">约 {{routeInfo.duration}} 分钟</text>
          </view>
        </view>
        <view class="route-item partner-route">
          <text class="route-icon">🎯</text>
          <view class="route-detail">
            <text class="route-distance">{{routeInfo.partnerDistance}}</text>
            <text class="route-time">对方约 {{routeInfo.partnerDuration}} 分钟</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 相遇点信息 -->
    <view class="meeting-info" wx:if="{{meetingPoint}}">
      <view class="meeting-header">
        <text class="meeting-title">🤝 推荐相遇点</text>
      </view>
      <view class="meeting-body">
        <text class="meeting-address">距离双方各约 {{meetingPoint.timeFromMe}} / {{meetingPoint.timeFromPartner}} 分钟</text>
        <text class="meeting-note">时间差仅 {{meetingPoint.timeDiff}} 分钟，适合见面</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button
        class="btn-route {{!partnerLocation.latitude ? 'disabled' : ''}}"
        bindtap="calculateRoute"
        disabled="{{!partnerLocation.latitude}}"
      >
        🛣️ 计算路线
      </button>
      <button
        class="btn-meeting {{!partnerLocation.latitude ? 'disabled' : ''}}"
        bindtap="calculateMeetingPoint"
        disabled="{{!partnerLocation.latitude}}"
      >
        🤝 计算相遇点
      </button>
    </view>

    <!-- 展开/收起 -->
    <view class="panel-toggle" bindtap="togglePanel">
      <text>{{panelExpanded ? '▲ 点击收起' : '▲ 点击查看更多'}}</text>
    </view>

  </view>

</view>