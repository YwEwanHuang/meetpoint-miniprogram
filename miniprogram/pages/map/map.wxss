/* 地图页 - Apple HIG Style */

page {
  --system-blue: #007AFF;
  --system-green: #34C759;
  --system-orange: #FF9500;
  --system-red: #FF3B30;
  --system-gray: #8E8E93;
  --system-gray-2: #AEAEB2;
  --system-gray-3: #C7C7CC;
  --system-gray-5: #E5E5EA;
  --system-gray-6: #F2F2F7;
  --system-gray-7: #FFFFFF;
  --label: #000000E5;
  --secondary-label: #00000099;
  --tertiary-label: #00000048;
  --separator: #0000001F;

  background: var(--system-gray-6);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
}

/* ========== 地图容器 ========== */
.map {
  width: 100%;
  height: 55vh;
}

/* ========== 地图工具栏 ========== */
.map-toolbar {
  position: absolute;
  top: 12px;
  left: 12px;
  right: 12px;
  display: flex;
  justify-content: space-between;
  z-index: 10;
  pointer-events: none;
}

.location-tag {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20px;
  font-size: 13px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.1);
  pointer-events: auto;
}

.tag-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.dot-blue {
  background: var(--system-blue);
}

.dot-green {
  background: var(--system-green);
}

.tag-text {
  color: var(--label);
  font-weight: 500;
}

/* ========== 刷新位置按钮 ========== */
.location-refresh-btn {
  position: absolute;
  bottom: calc(45vh + 60px);
  right: 16px;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  padding: 0;
  background: var(--system-gray-7);
  border: 0.5px solid var(--system-gray-5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  z-index: 10;
  line-height: 1;
}

.refresh-icon {
  font-size: 22px;
  font-weight: 300;
  color: var(--system-blue);
}

/* ========== 定位状态指示 ========== */
.loc-status {
  position: absolute;
  bottom: calc(45vh + 60px);
  left: 16px;
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(255, 255, 255, 0.95);
  padding: 6px 12px;
  border-radius: 20px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.1);
  z-index: 10;
}

.loc-pulse {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--system-green);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.loc-status-text {
  font-size: 12px;
  color: var(--system-green);
  font-weight: 500;
}

/* ========== 底部面板 ========== */
.bottom-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--system-gray-7);
  border-radius: 20px 20px 0 0;
  box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.08);
  padding: 16px 20px 24px;
  z-index: 20;
  transition: transform 0.3s ease;
  padding-bottom: calc(24px + env(safe-area-inset-bottom, 0px));
}

/* ========== 面板手柄 ========== */
.panel-handle {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  z-index: 25;
  padding: 8px 0 12px;
  width: 60px;
  text-align: center;
}

.handle-bar {
  width: 36px;
  height: 4px;
  background: var(--system-gray-3);
  border-radius: 2px;
}

/* ========== 交通方式选项卡 ========== */
.transport-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10px 0;
  border-radius: 10px;
  font-size: 17px;
  color: var(--secondary-label);
  background: transparent;
  transition: all 0.2s;
}

.tab-item.active {
  background: var(--system-gray-6);
  color: var(--system-blue);
  font-weight: 600;
}

.tab-item:active {
  opacity: 0.7;
}

.tab-icon {
  font-size: 20px;
  margin-bottom: 4px;
}

.tab-label {
  font-size: 12px;
  font-weight: 500;
}

/* ========== 路线信息 ========== */
.route-info {
  background: var(--system-gray-6);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.route-row {
  display: flex;
  align-items: center;
}

.route-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.route-label {
  font-size: 13px;
  color: var(--secondary-label);
  font-weight: 500;
}

.route-value {
  font-size: 22px;
  font-weight: 700;
  color: var(--label);
  letter-spacing: -0.5px;
}

.route-sub {
  font-size: 12px;
  color: var(--tertiary-label);
}

.route-divider {
  width: 1px;
  height: 40px;
  background: var(--separator);
  margin: 0 16px;
}

/* ========== 相遇点信息 ========== */
.meeting-info {
  margin-bottom: 16px;
}

.meeting-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  background: #FFF8E1;
  border-radius: 10px;
}

.meeting-icon {
  font-size: 24px;
}

.meeting-details {
  flex: 1;
}

.meeting-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--label);
  display: block;
}

.meeting-desc {
  font-size: 13px;
  color: var(--system-orange);
  display: block;
  margin-top: 2px;
}

/* ========== 操作按钮 ========== */
.action-buttons {
  display: flex;
  gap: 10px;
}

.btn-action {
  flex: 1;
  height: 48px;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.btn-route {
  background: var(--system-blue);
  color: #FFFFFF;
}

.btn-route:active:not(.disabled) {
  opacity: 0.8;
}

.btn-meeting {
  background: var(--system-green);
  color: #FFFFFF;
}

.btn-meeting:active:not(.disabled) {
  opacity: 0.8;
}

.btn-action.disabled {
  background: var(--system-gray-5);
  color: var(--system-gray);
}

/* ========== 收起展开 ========== */
.panel-toggle {
  text-align: center;
  font-size: 12px;
  color: var(--tertiary-label);
  padding: 4px 0;
}
