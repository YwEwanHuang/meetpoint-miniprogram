<!-- 设置页 - Apple HIG Style -->
<view class="page">

  <!-- Large Title -->
  <view class="large-title">设置</view>

  <!-- 交通偏好 -->
  <view class="section">
    <view class="section-header">出行偏好</view>
    <view class="card list-card">
      <view class="transport-options">
        <view
          wx:for="{{transportModes}}"
          wx:key="mode"
          class="option-item {{defaultMode === item.mode ? 'selected' : ''}}"
          bindtap="selectMode"
          data-mode="{{item.mode}}"
        >
          <text class="option-icon">{{item.icon}}</text>
          <text class="option-label">{{item.label}}</text>
          <text class="option-check" wx:if="{{defaultMode === item.mode}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="section">
    <view class="section-header">关于</view>
    <view class="card list-card">
      <view class="list-item">
        <view class="list-item-left">
          <text class="list-item-label">版本</text>
        </view>
        <view class="list-item-right">
          <text>1.0.0</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 危险操作 -->
  <view class="section danger-section">
    <view class="danger-card">
      <view class="danger-header">
        <text class="danger-title">解除配对</text>
        <text class="danger-desc">解除后将不再共享位置和见面记录</text>
      </view>
      <button class="btn-unpair" bindtap="unpair">解除当前配对</button>
    </view>
  </view>

  <view class="version-info">
    <text>约见 MeetPoint v1.0.0</text>
  </view>

</view>
